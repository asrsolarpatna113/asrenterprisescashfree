modules = ["nodejs-20", "python-3.12", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["cargo", "freetype", "glibcLocales", "lcms2", "libiconv", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "rustc", "tcl", "tk", "zlib"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c 'set -e; MONGO_URL=mongodb://127.0.0.1:27017 DB_NAME=asr_dev USE_IN_MEMORY_MONGO=true CORS_ORIGINS=\"*\" PYTHONPATH=backend python -m uvicorn server:app --app-dir backend --host 127.0.0.1 --port 8000 & backend_pid=$!; trap \"kill $backend_pid 2>/dev/null || true\" EXIT INT TERM; cd frontend; REACT_APP_BACKEND_URL= REACT_APP_BACKEND_PROXY=http://127.0.0.1:8000 npm start'"
waitForPort = 5000

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "export MONGO_URL=\"${MONGO_URL:-mongodb://127.0.0.1:27017}\" DB_NAME=\"${DB_NAME:-asr_dev}\" USE_IN_MEMORY_MONGO=\"${USE_IN_MEMORY_MONGO:-true}\" CORS_ORIGINS=\"${CORS_ORIGINS:-*}\" PYTHONPATH=backend; python -m uvicorn server:app --app-dir backend --host 0.0.0.0 --port \"${PORT:-5000}\""]
build = ["bash", "-c", "cd frontend && npm install --no-audit --no-fund && npm run build"]
